# Django
SECRET_KEY=changeme-secret-key-placeholder
# Debug mode. MUST be False in production.
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://django_base:changeme@localhost:5432/django_base

# PostgreSQL (required for docker-compose.prod.yml)
POSTGRES_PASSWORD=changeme-postgres-password

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF trusted origins (comma-separated, update for production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# JWT (optional, defaults shown)
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME=15
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME=7

# Sentry (optional, leave blank to disable)
SENTRY_DSN=

# Admin IP whitelist (optional, comma-separated IPs; empty = allow all)
ADMIN_IP_WHITELIST=

# Production settings (optional, used in production.py)
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
